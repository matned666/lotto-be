<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-lotto-card-schema" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="LOTTO_CARD"/>
            </not>
        </preConditions>

        <createTable tableName="LOTTO_NUMBERS">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_LOTTO_NUMBERS" nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="LOTTO_CARD">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_LOTTO_CARD" nullable="false"/>
            </column>
            <column name="OWNER_SUBJECT" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="FIRST_DRAW_DATE" type="DATE"/>
            <column name="NUMBER_OF_DRAWINGS" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="DRAW_TYPE" type="VARCHAR(255)"/>
        </createTable>

        <createTable tableName="LOTTO_CARD_NUMBERS">
            <column name="LOTTO_CARD_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="LOTTO_NUMBERS_ID" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_LOTTO_CARD_NUMBERS_NUMBERS"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="LOTTO_CARD_NUMBERS"
                                 baseColumnNames="LOTTO_CARD_ID"
                                 constraintName="FK_LOTTO_CARD_NUMBERS_CARD"
                                 referencedTableName="LOTTO_CARD"
                                 referencedColumnNames="ID"/>

        <addForeignKeyConstraint baseTableName="LOTTO_CARD_NUMBERS"
                                 baseColumnNames="LOTTO_NUMBERS_ID"
                                 constraintName="FK_LOTTO_CARD_NUMBERS_NUMBERS"
                                 referencedTableName="LOTTO_NUMBERS"
                                 referencedColumnNames="ID"/>

        <createTable tableName="LOTTO_NUMBERS_VALUES">
            <column name="LOTTO_NUMBERS_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="NUMBER_VALUE" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="LOTTO_NUMBERS_VALUES"
                                 baseColumnNames="LOTTO_NUMBERS_ID"
                                 constraintName="FK_LOTTO_NUMBERS_VALUES_NUMBERS"
                                 referencedTableName="LOTTO_NUMBERS"
                                 referencedColumnNames="ID"/>

        <createIndex tableName="LOTTO_CARD" indexName="IDX_LOTTO_CARD_OWNER_ID">
            <column name="OWNER_SUBJECT"/>
            <column name="ID" descending="true"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-user-table" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="USERS"/>
            </not>
        </preConditions>

        <createTable tableName="USERS">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_USERS" nullable="false"/>
            </column>
            <column name="EMAIL" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_USERS_EMAIL"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="AVATAR_URL" type="VARCHAR(255)"/>
            <column name="CREATED_AT" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="UPDATED_AT" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <changeSet id="003-create-oauth-accounts-table" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="OAUTH_ACCOUNTS"/>
            </not>
        </preConditions>

        <createTable tableName="OAUTH_ACCOUNTS">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_OAUTH_ACCOUNTS" nullable="false"/>
            </column>
            <column name="USER_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="PROVIDER_TYPE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PROVIDER_USER_ID" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="OAUTH_ACCOUNTS"
                                 baseColumnNames="USER_ID"
                                 constraintName="FK_OAUTH_ACCOUNTS_USER"
                                 referencedTableName="USERS"
                                 referencedColumnNames="ID"/>

        <addUniqueConstraint tableName="OAUTH_ACCOUNTS"
                             columnNames="PROVIDER_TYPE, PROVIDER_USER_ID"
                             constraintName="UK_OAUTH_ACCOUNTS_PROVIDER_USER"/>
    </changeSet>

    <changeSet id="004-create-authority-table" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="AUTHORITY"/>
            </not>
        </preConditions>
        <createTable tableName="AUTHORITY">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="005-create-user-authorities-table" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="USER_AUTHORITIES"/>
            </not>
        </preConditions>
        <createTable tableName="USER_AUTHORITIES">
            <column name="USER_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="AUTHORITY_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
                tableName="USER_AUTHORITIES"
                columnNames="USER_ID,AUTHORITY_ID"
                constraintName="PK_USER_AUTHORITIES"/>
        <addForeignKeyConstraint
                baseTableName="USER_AUTHORITIES"
                baseColumnNames="USER_ID"
                referencedTableName="USERS"
                referencedColumnNames="ID"
                constraintName="FK_USER_AUTHORITIES_USER"/>
        <addForeignKeyConstraint
                baseTableName="USER_AUTHORITIES"
                baseColumnNames="AUTHORITY_ID"
                referencedTableName="AUTHORITY"
                referencedColumnNames="ID"
                constraintName="FK_USER_AUTHORITIES_AUTHORITY"/>
    </changeSet>

    <changeSet id="006-insert-role-user" author="mateusz">
        <preConditions onFail="MARK_RAN">
            <not>
                <sqlCheck expectedResult="1">
                    SELECT COUNT(*)
                    FROM AUTHORITY
                    WHERE NAME = 'ROLE_USER'
                </sqlCheck>
            </not>
        </preConditions>
        <insert tableName="AUTHORITY">
            <column name="NAME" value="ROLE_USER"/>
        </insert>
    </changeSet>

    <changeSet id="007-insert-role-admin" author="mateusz">
        <preConditions onFail="MARK_RAN">
            <not>
                <sqlCheck expectedResult="1">
                    SELECT COUNT(*)
                    FROM AUTHORITY
                    WHERE NAME = 'ROLE_ADMIN'
                </sqlCheck>
            </not>
        </preConditions>
        <insert tableName="AUTHORITY">
            <column name="NAME" value="ROLE_ADMIN"/>
        </insert>
    </changeSet>

    <changeSet id="008-assign-role-user-to-existing-users" author="mateusz">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT CASE
                           WHEN EXISTS (
                               SELECT 1
                               FROM USERS u
                                        JOIN AUTHORITY a ON a.NAME = 'ROLE_USER'
                               WHERE NOT EXISTS (
                                   SELECT 1
                                   FROM USER_AUTHORITIES ua
                                   WHERE ua.USER_ID = u.ID
                                     AND ua.AUTHORITY_ID = a.ID
                               )
                           )
                               THEN 1
                           ELSE 0
                           END
            </sqlCheck>
        </preConditions>
        <sql>
            INSERT INTO USER_AUTHORITIES (USER_ID, AUTHORITY_ID)
            SELECT
                u.ID,
                a.ID
            FROM USERS u
                     JOIN AUTHORITY a
                          ON a.NAME = 'ROLE_USER'
            WHERE NOT EXISTS (
                SELECT 1
                FROM USER_AUTHORITIES ua
                WHERE ua.USER_ID = u.ID
                  AND ua.AUTHORITY_ID = a.ID
            );
        </sql>
    </changeSet>

    <changeSet id="009-insert-role-blocked" author="mateusz">
        <preConditions onFail="MARK_RAN">
            <not>
                <sqlCheck expectedResult="1">
                    SELECT COUNT(*)
                    FROM AUTHORITY
                    WHERE NAME = 'ROLE_BLOCKED'
                </sqlCheck>
            </not>
        </preConditions>
        <insert tableName="AUTHORITY">
            <column name="NAME" value="ROLE_BLOCKED"/>
        </insert>
    </changeSet>

    <changeSet id="010-create-properties-table" author="matned">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <tableExists tableName="PROPERTIES"/>
            </not>
        </preConditions>
        <createTable tableName="PROPERTIES">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_PROPERTIES"
                             nullable="false"/>
            </column>
            <column name="USER_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="TYPE" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="VALUE" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="ENABLED" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="PROPERTIES"
                baseColumnNames="USER_ID"
                constraintName="FK_PROPERTIES_USER"
                referencedTableName="USERS"
                referencedColumnNames="ID"/>
        <createIndex tableName="PROPERTIES"
                     indexName="IDX_PROPERTIES_USER_ID">
            <column name="USER_ID"/>
        </createIndex>
    </changeSet>

    <changeSet id="011-insert-sample-property" author="matned">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="PROPERTIES"/>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*)
                FROM PROPERTIES
                WHERE USER_ID = 1
                  AND NAME = 'notifications.enabled'
            </sqlCheck>
        </preConditions>
        <insert tableName="users"><column name="id" valueNumeric="0"/><column name="name" value="DEFAULT"/><column name="email" value="default@email.pl"/></insert>
        <insert tableName="PROPERTIES"><column name="USER_ID" valueNumeric="0"/><column name="TYPE" value="BOOLEAN"/><column name="NAME" value="prop.notifications.enabled"/><column name="VALUE" value="false"/><column name="ENABLED" valueBoolean="false"/></insert>
        <insert tableName="PROPERTIES"><column name="USER_ID" valueNumeric="0"/><column name="TYPE" value="BOOLEAN"/><column name="NAME" value="prop.lotto.check.scheduler.enabled"/><column name="VALUE" value="false"/><column name="ENABLED" valueBoolean="true"/></insert>
        <insert tableName="PROPERTIES"><column name="USER_ID" valueNumeric="0"/><column name="TYPE" value="SCHEDULER"/><column name="NAME" value="prop.lotto.check.time"/><column name="VALUE" value="0 0 22 * * TUE,THU,SAT"/><column name="ENABLED" valueBoolean="true"/></insert>
        <insert tableName="PROPERTIES"><column name="USER_ID" valueNumeric="0"/><column name="TYPE" value="EMAIL"/><column name="NAME" value="prop.data.email"/><column name="VALUE" value=""/><column name="ENABLED" valueBoolean="true"/></insert>
    </changeSet>

</databaseChangeLog>
