<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-lotto-card-schema" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="LOTTO_CARD"/>
            </not>
        </preConditions>

        <createTable tableName="LOTTO_NUMBERS">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_LOTTO_NUMBERS" nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="LOTTO_CARD">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_LOTTO_CARD" nullable="false"/>
            </column>
            <column name="OWNER_SUBJECT" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="FIRST_DRAW_DATE" type="DATE"/>
            <column name="NUMBER_OF_DRAWINGS" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="DRAW_TYPE" type="VARCHAR(255)"/>
        </createTable>

        <createTable tableName="LOTTO_CARD_NUMBERS">
            <column name="LOTTO_CARD_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="LOTTO_NUMBERS_ID" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_LOTTO_CARD_NUMBERS_NUMBERS"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="LOTTO_CARD_NUMBERS"
                                 baseColumnNames="LOTTO_CARD_ID"
                                 constraintName="FK_LOTTO_CARD_NUMBERS_CARD"
                                 referencedTableName="LOTTO_CARD"
                                 referencedColumnNames="ID"/>

        <addForeignKeyConstraint baseTableName="LOTTO_CARD_NUMBERS"
                                 baseColumnNames="LOTTO_NUMBERS_ID"
                                 constraintName="FK_LOTTO_CARD_NUMBERS_NUMBERS"
                                 referencedTableName="LOTTO_NUMBERS"
                                 referencedColumnNames="ID"/>

        <createTable tableName="LOTTO_NUMBERS_VALUES">
            <column name="LOTTO_NUMBERS_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="NUMBER_VALUE" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="LOTTO_NUMBERS_VALUES"
                                 baseColumnNames="LOTTO_NUMBERS_ID"
                                 constraintName="FK_LOTTO_NUMBERS_VALUES_NUMBERS"
                                 referencedTableName="LOTTO_NUMBERS"
                                 referencedColumnNames="ID"/>

        <createIndex tableName="LOTTO_CARD" indexName="IDX_LOTTO_CARD_OWNER_ID">
            <column name="OWNER_SUBJECT"/>
            <column name="ID" descending="true"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-user-table" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="USERS"/>
            </not>
        </preConditions>

        <createTable tableName="USERS">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_USERS" nullable="false"/>
            </column>
            <column name="EMAIL" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_USERS_EMAIL"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="AVATAR_URL" type="VARCHAR(255)"/>
            <column name="CREATED_AT" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="UPDATED_AT" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <changeSet id="003-create-oauth-accounts-table" author="matned">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="OAUTH_ACCOUNTS"/>
            </not>
        </preConditions>

        <createTable tableName="OAUTH_ACCOUNTS">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_OAUTH_ACCOUNTS" nullable="false"/>
            </column>
            <column name="USER_ID" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="PROVIDER_TYPE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PROVIDER_USER_ID" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="OAUTH_ACCOUNTS"
                                 baseColumnNames="USER_ID"
                                 constraintName="FK_OAUTH_ACCOUNTS_USER"
                                 referencedTableName="USERS"
                                 referencedColumnNames="ID"/>

        <addUniqueConstraint tableName="OAUTH_ACCOUNTS"
                             columnNames="PROVIDER_TYPE, PROVIDER_USER_ID"
                             constraintName="UK_OAUTH_ACCOUNTS_PROVIDER_USER"/>
    </changeSet>
</databaseChangeLog>
